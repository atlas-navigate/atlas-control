# Atlas Control — persistent device symlinks
# Install: sudo cp 99-atlas-devices.rules /etc/udev/rules.d/
#          sudo udevadm control --reload-rules && sudo udevadm trigger

# Heltec WiFi LoRa 32 v4 (Espressif 303a:1001) over USB-C. When the Heltec is
# instead wired to the 40-pin header (pins 8=TX, 10=RX) it presents NOT as USB
# but as the on-board UART /dev/ttyTHS1 — no udev symlink applies; access is via
# the dialout group (granted by install.sh) and mesh_manager.py probes the UART
# and connects at the fixed 115200-baud meshtastic client-API rate.
SUBSYSTEM=="tty", ATTRS{idVendor}=="303a", ATTRS{idProduct}=="1001", SYMLINK+="meshtastic", MODE="0666"
# Some Meshtastic ESP32-S3 firmware presents the native USB as a TinyUSB CDC
# device (303a:4001) instead of the ROM USB-Serial/JTAG (303a:1001). Match both
# so a flashed Heltec V4 gets /dev/meshtastic in either USB mode. NOTE: if lsusb
# shows NO 303a device at all, the board isn't enumerating — a hardware issue
# (charge-only cable, power, or missing/re-flashed firmware), not a rule gap.
SUBSYSTEM=="tty", ATTRS{idVendor}=="303a", ATTRS{idProduct}=="4001", SYMLINK+="meshtastic", MODE="0666"

# u-blox NEO-M8U GPS over USB (1546:01a8). When the GPS is instead wired to
# the 40-pin header it presents NOT as a tty but as I2C/DDC on /dev/i2c-7 at
# address 0x42 (header pins 3=SDA, 5=SCL) — no udev symlink applies; access is
# via the i2c group (granted by install.sh) and gps_node.py auto-detects it.
SUBSYSTEM=="tty", ATTRS{idVendor}=="1546", ATTRS{idProduct}=="01a8", SYMLINK+="gps", MODE="0666"
