# Atlas Control — persistent device symlinks
# Install: sudo cp 99-atlas-devices.rules /etc/udev/rules.d/
#          sudo udevadm control --reload-rules && sudo udevadm trigger

# Heltec WiFi LoRa 32 v4 (Espressif 303a:1001)
SUBSYSTEM=="tty", ATTRS{idVendor}=="303a", ATTRS{idProduct}=="1001", SYMLINK+="meshtastic", MODE="0666"

# u-blox NEO-M8U GPS (1546:01a8)
SUBSYSTEM=="tty", ATTRS{idVendor}=="1546", ATTRS{idProduct}=="01a8", SYMLINK+="gps", MODE="0666"
